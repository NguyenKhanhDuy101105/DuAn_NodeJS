header.header.bg-white.shadow-sm.py-3.border-bottom.sticky-top
  .container
    .row.align-items-center
      // Khối Logo
      .col-md-3.col-6
        .inner-logo
          a(href="/" class="d-inline-block transition-all")
            img(src="/images/logo.svg" alt="Logo" style="height: 45px; object-fit: contain;")
      
      // Khối Menu hướng về bên phải
      .col-md-9.col-6
        .inner-menu.d-flex.justify-content-start
          ul.nav.nav-pills.align-items-center.gap-2.gap-md-4.m-0.p-0
            li.nav-item
              a.nav-link.active.fw-semibold.px-3.py-2(href="/" style="border-radius: 8px;") Trang chủ
            li.nav-item
              a.nav-link.text-dark.fw-semibold.px-3.py-2(href="/products" style="border-radius: 8px;") Sản phẩm