doctype html
html
  head
    title #{titlePage}
    link(rel="stylesheet" href="/admin/css/style.css")
    link(href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet")
    link(rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css")
  body.bg-light
    // 1. Thanh Header cố định nằm trên cùng, tràn viền màn hình
    include ../partials/header.pug

    // 2. Khu vực thân trang nằm dưới Header (Dùng container-fluid tràn viền)
    .container-fluid
      .row
        // Thanh Sider nằm bên trái, chiếm 3 cột trên màn hình Medium trở lên
        .col-xl-2.col-md-3.p-0.bg-dark.shadow(style="min-vh: calc(100vh - 73px);")
          include ../partials/sider.pug

        // Phần nội dung chính nằm bên phải, chiếm phần còn lại (9 hoặc 10 cột)
        .col-xl-10.col-md-9.p-4
          .main-content
            block main

    script(src="/admin/js/script.js") 
    script(src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js")