extends ../../layouts/default.pug
include ../../mixins/message-success.pug

block main
  //- Hiển thị thông báo nếu có
  +message-success(3000)
  +message-error(3000)

  .container-fluid.py-4
    .mb-4
      a.btn.btn-outline-secondary.btn-sm(href=`${prefixAdmin}/products`) 
        i.fas.fa-arrow-left.me-1
        | Trở về danh sách

    .card.shadow-sm.border-0.rounded-3
      .card-body.p-4
        .row.g-4
          //- 1. Bên trái: Khung hiển thị hình ảnh sản phẩm
          .col-md-5.col-lg-4
            if (product.thumbnail)
              .ratio.ratio-4x3.border.rounded-3.overflow-hidden.bg-light
                img(
                  src=product.thumbnail 
                  alt=product.title 
                  style="object-fit: cover; width: 100%; height: 100%;"
                )
            else
              .ratio.ratio-4x3.border.rounded-3.overflow-hidden.bg-light.d-flex.align-items-center.justify-content-center
                span.text-muted Không có hình ảnh

          //- 2. Bên phải: Khung hiển thị thông tin chi tiết
          .col-md-7.col-lg-8.d-flex.flex-column.justify-content-between
            div
              //- Tiêu đề sản phẩm
              if (product.title)
                h1.mb-3.fw-bold.text-dark #{product.title}

              //- Khối hiển thị Giá tiền & Giảm giá
              .d-flex.align-items-center.gap-3.mb-3
                if (product.price)
                  //- Tính toán giá thực tế sau khi giảm phần trăm
                  - var finalPrice = (product.price * (1 - (product.discountPercentage || 0) / 100)).toFixed(2)
                  span.fs-3.fw-bold.text-danger $#{finalPrice}
                  
                  if (product.discountPercentage > 0)
                    span.text-decoration-line-through.text-muted.fs-5 $#{product.price}
                    span.badge.bg-warning.text-dark.fw-semibold -#{product.discountPercentage}%

              //- Trạng thái hoạt động (Badge màu)
              .mb-3
                span.text-secondary.me-2 Trạng thái:
                if (product.status === "active")
                  span.badge.bg-success.bg-opacity-10.text-success.px-2.py-1 Hoạt động
                else
                  span.badge.bg-danger.bg-opacity-10.text-danger.px-2.py-1 Dừng hoạt động

              //- Thông tin kho hàng và vị trí
              .row.g-2.mb-4
                if (product.stock !== undefined)
                  .col-6.col-md-4
                    .p-2.bg-light.rounded-2
                      small.text-muted.d-block Kho hàng
                      span.fw-semibold.text-dark #{product.stock} sản phẩm
                
                if (product.position !== undefined)
                  .col-6.col-md-4
                    .p-2.bg-light.rounded-2
                      small.text-muted.d-block Vị trí sắp xếp
                      span.fw-semibold.text-dark ##{product.position}

              //- Mô tả sản phẩm
              if (product.description)
                .mb-3
                  h5.fw-bold.text-secondary.border-bottom.pb-2 Mô tả sản phẩm
                  p.text-muted.lh-base(style="white-space: pre-line;") #{product.description}

            //- 3. Dưới cùng bên phải: Các nút hành động nhanh
            .d-flex.gap-2.mt-4.border-top.pt-3
              a.btn.btn-warning.text-white.px-3(href=`${prefixAdmin}/products/edit/${product.id}`)
                i.fas.fa-edit.me-1
                | Chỉnh sửa
              
              if (product.deleted)
                a.btn.btn-primary.px-3(data-id=product.id button-restore) Khôi phục
              else
                a.btn.btn-danger.px-3(data-id=product.id buttonDelete) Xóa sản phẩm
    //- Form de xoa san pham
    form(
        action=`` 
        method="POST" 
        id="form-delete-item" 
        data-path=`${prefixAdmin}/products/delete`
        )
    //- Form de khoi phuc san pham
    form(
        action=`` 
        method="POST" 
        id="form-restore-item" 
        data-path=`${prefixAdmin}/products/restore`
        ) 
 
  script(src="/admin/js/product.js")