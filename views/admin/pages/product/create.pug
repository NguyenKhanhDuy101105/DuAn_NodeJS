extends ../../layouts/default.pug
include ../../mixins/message-success.pug
include ../../mixins/tinymce.pug
include ../../mixins/select_tree.pug

block main
  +message-error(3000)

  h1 Them moi san pham

  form(
    action =`${prefixAdmin}/products/create`
    id="form-create-product"
    method="POST"
    enctype="multipart/form-data"
  ) 
    .form-group 
      label(for="title") Tieu de 
      input(type="text" class="form-control" id="title" name="title")
    
    .form-group 
      label(for="product_category_id") Danh muc
      select(name="product_category_id" id="product_category_id" class="form-control")
        option(value=`` disable) == Chon danh muc ==
        +select_tree(newList) 

    +tinymce("Mô tả sản phẩm", "desc", "description", 5)
    
    //- +tinymce("Noi dung", "content", "content", 5)
    .form-group 
      label(for="price") Gia
      input(type="number" class="form-control" id="price" name="price" value="0" min="0" )

    .form-group 
      label(for="discountPercentage") % Gia gia
      input(type="number" class="form-control" id="discountPercentage" name="discountPercentage" value="0" min="0")
    
    .form-group 
      label(for="stock") So luong
      input(type="number" class="form-control" id="stock" name="stock" value="0" min="0" )

    .form-group(upload-image) 
      label(for="thumbnail") Anh
      br
      input(upload-image-input type="file" class="form-control-file" id="thumbnail" name="thumbnail" accept="image/*" )
      br
      .position-relative.d-inline-block.mt-2
        img(upload-image-preview class="img-thumbnail" style="width: 300px; height: 200px; object-fit: cover;" src="" alt="")
        //- Nút X mặc định ẩn đi bằng class d-none của Bootstrap
        button.btn.btn-sm.btn-danger.position-absolute.top-0.end-0.m-1.d-none(type="button" btn-delete-preview) X


    .form-group 
      label(for="position") Vi tri
      input(type="number" class="form-control" id="position" name="position" placeholder="Tu dong tang" min="1")

    .form-group.form-check.form-check-inline 
      input(type="radio" class="form-check-input" id="statusActive" name="status" value="active" checked)
      label(for="statusActive" class="form-check-label") Hoat dong
    .form-group.form-check.form-check-inline
      input(type="radio" class="form-check-input" id="statusInactive" name="status" value="inactive")
      label(for="statusInactive" class="form-check-label") Dung hoat dong

    .form-group 
      button.btn.btn-primary(type="submit") Tao moi 
    
    script(src="/admin/js/product.js")